<section class="team__board subsection">

{% for role in roles %}
    <div class="{{role.name === 'president' ? 'president' : ''}}">
        <h2 class="subsection__title">{{ role.name }}</h2>
            <div class="{{role.name !== 'president' ? 'team__container' : ''}}">
                {% for member in role.members %}

                    {% set tag = role.name == 'president' ? 'a' : 'div' %}

                        <{{ tag }}
                            class="team__card"
                            {% if tag == 'a' %}
                                href="{{ path('app_eulogy') }}"
                            {% endif %}
                        >

                            <img src="{{ member.image ? asset(member.image) : asset('images/team/default-user-picture.png') }}" alt="{{ member.name }}">
                            <div class="team__card__text">
                                <h3 class="team__card__name">{{ member.name }}</h3>
                                <p class="team__card__bio">{{ member.presentation }}</p>
                            </div>

                        </{{ tag }}>

                {% endfor %}
            </div>
    </div>
{% endfor %}

</section>