{% extends 'base.html.twig' %}

{% block title %}Association TAM : Hommage au Dr Maman Bello{% endblock %}

{% block body %}
    <main>
        {% include "partials/_left_banner.html.twig" %}
            <section class="eulogy section">
                {% if rubricInfo.title is not empty or rubricInfo.getGalleryImage.path is defined or rubricInfo.text is empty %}
                <section>
                    <h1 class="section__title">{{ rubricInfo.title }}</h1>
                    {% if rubricInfo.getGalleryImage is not empty %}
                    <img  class="section__image" src="{{ asset(rubricInfo.getGalleryImage.path) }}" alt="{{ rubricInfo.getGalleryImage.alt }}">
                    {% endif %}
                    <div class="subsection__text">{{ rubricInfo.text|quill_html|raw }}</div>
                </section>
                {% endif %}

            {% for eulogySection in eulogySections %}

                <section class="subsection">
                    {% if eulogySection.title is not empty %}
                        <h2
                            class="subsection__title {{ eulogySection === eulogySections[0] ? 'subsection__title-grid' : '' }}">
                            {{ eulogySection.title }}
                        </h2>
                    {% endif %}
                    {% if eulogySection === eulogySections[0] %}
                        <img class="eulogy__image left" src="{{ president.image ? asset(president.image) : asset('images/team/default-user-picture.png') }}" alt="{{ [president.firstname, president.lastname]|join }}">
                    {% endif %}
                    <div class="subsection__text">{{ eulogySection.text|quill_html|raw }}</div>
                </section>

                {% endfor %}
            </section>
        {% include "partials/_right_banner.html.twig" %}
    </main>
{% endblock %}
