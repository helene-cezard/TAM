    {% set currentRoute = app.request.attributes.get('_route') %}

<header id="header" class="header" role="banner">
    {% if adminInterface %}
    <div class="header__admin">
        <p>Vous êtes dans l'interface d'administration</p>
    </div>
    {% endif %}
    <div class="header__nav">
        <div class="header__logo" id="toggleNavbar">
            <img src="{{ asset('images/logo-transparent-bg.png') }}" alt="Logo de l'association TAM">
        </div>
        <button type="button" aria-haspopup="true" aria-expanded="false" aria-controls="nav" id="icons" class="header__buttons" aria-label="Ouvrir ou fermer le menu de navigation">
            <span class="sr-only">Menu</span>
        </button>
        <nav id="nav" role="navigation" class="header__navbar">
            <ul role="menubar" class="header__nav-links">
            {% if app.user %}
                <li class="header__nav-links--blue parent__menu">
                    <button type="button" aria-haspopup="true" aria-expanded="false" aria-controls="connected" class="submenu__button">👤 Connecté</button>
                    <ul role="menu" id="connected" class="submenu">
                        <li class="submenu__item">

                            {% if adminInterface %}
                            <a href="{{ path('app_home') }}"
                            role="menuitem"
                            aria-label="Retour au site"
                            title="Retour au site"
                            class="header__logout">
                            Retour au site
                            </a>

                            {% else %}
                            <a href="{{ path('admin_home') }}"
                            role="menuitem"
                            aria-label="Espace administration"
                            title="Espace administration">
                            Espace administration
                            </a>
                            {% endif %}


                        </li>
                        <li class="submenu__item">
                            <a href="{{ path('app_logout') }}"
                            role="menuitem"
                            class="header__logout"
                            aria-label="Se déconnecter"
                            title="Se déconnecter">
                            Se déconnecter
                            </a>
                        </li>
                    </ul>
                </li>
            {% endif %}
                <li class="header__nav-links--yellow">
                    <a {{ currentRoute == 'app_home' or currentRoute == 'admin_home' ? 'class="active" aria-current="page"':'' }} role="menuitem" href="{{ path(adminInterface ? 'admin_home' : 'app_home') }}">Accueil</a>
                </li>
                <li class="header__nav-links--blue parent__menu">
                    <button {{ 'app_who' in currentRoute or 'association' in currentRoute or 'team' in currentRoute or 'reports' in currentRoute ? 'class="active" aria-current="page"':'' }} type="button" aria-haspopup="true" aria-expanded="false" aria-controls="who_submenu" class="submenu__button">Qui sommes-nous ?</button>
                    <ul role="menu" id="who_submenu" class="submenu">
                        <li class="submenu__item">
                            <a role="menuitem" href="{{ path(adminInterface ? 'admin_association' : 'app_who_association') }}">L'association</a>
                        </li>
                        <li class="submenu__item">
                            <a role="menuitem" href="{{ path(adminInterface ? 'admin_team' : 'app_who_team') }}">L'équipe</a>
                        </li>
                        <li class="submenu__item">
                            <a role="menuitem" href="{{ path(adminInterface ? 'admin_reports' : 'app_who_reports') }}">Rapports d'activité</a>
                        </li>
                    </ul>
                </li>
                <li class="header__nav-links--green parent__menu">
                    <button {{ 'app_actions' in currentRoute or 'france' in currentRoute or 'benin' in currentRoute ? 'class="active" aria-current="page"':'' }} type="button" aria-haspopup="true" aria-expanded="false" aria-controls="actions_submenu" class="submenu__button">Actions</button>
                    <ul role="menu" id="actions_submenu" class="submenu">
                        <li class="submenu__item">
                            <a role="menuitem" href="{{ path(adminInterface ? 'admin_france' : 'app_actions_france') }}">En France</a>
                        </li>
                        <li class="submenu__item">
                            <a role="menuitem" href="{{ path(adminInterface ? 'admin_benin' : 'app_actions_benin') }}">Au Bénin</a>
                        </li>
                    </ul>
                </li>
                <li class="header__nav-links--orange">
                    <a {{ currentRoute == 'app_training' or currentRoute == 'admin_training' ? 'class="active" aria-current="page"':'' }} role="menuitem" href="{{ path( adminInterface ? 'admin_training' : 'app_training') }}">Formation</a>
                </li>
                <li class="header__nav-links--turquoise">
                    <a {{ currentRoute == 'app_resources' or currentRoute == 'admin_resources' ? 'class="active" aria-current="page"':'' }} role="menuitem" href="{{ path( adminInterface ? 'admin_resources' : 'app_resources') }}">Ressources</a>
                </li>
                <li class="header__nav-links--light-blue">
                    <a {{ currentRoute == 'app_contact' or currentRoute == 'admin_contact' ? 'class="active" aria-current="page"':'' }} role="menuitem" href="{{ path( adminInterface ? 'admin_contact' : 'app_contact') }}">Contact</a>
                </li>
            </ul>
        </nav>
    </div>
    <div id="js-data" data-current-route="{{ app.current_route }}"></div>
</header>